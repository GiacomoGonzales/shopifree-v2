# Fastfile — white-label iOS release lane for Shopifree store apps.
#
# Usage from CI:
#   fastlane release
#
# Expects env vars:
#   STORE_ID, BUILD_NUMBER, VERSION_NAME
#   APPSTORE_API_KEY_ID, APPSTORE_API_ISSUER_ID
#   APPLE_TEAM_ID, MATCH_GIT_URL, MATCH_PASSWORD, MATCH_GIT_BASIC_AUTHORIZATION
#
# The App Store Connect API key (.p8) is expected at
#   ~/.appstoreconnect/private_keys/AuthKey.p8
# (decoded by the workflow before fastlane runs).

default_platform(:ios)

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build and upload to TestFlight"
  lane :release do
    # 1) Authenticate to App Store Connect via API key (no Apple ID/2FA)
    api_key = app_store_connect_api_key(
      key_id: ENV["APPSTORE_API_KEY_ID"],
      issuer_id: ENV["APPSTORE_API_ISSUER_ID"],
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey.p8"),
      in_house: false
    )

    # 2) Bundle id + app name come from the workflow (read from .build-meta.json).
    # Info.plist still has unexpanded $(PRODUCT_BUNDLE_IDENTIFIER) at this point,
    # so we can't read it from there — Capacitor writes the real value into
    # the Xcode project, and Xcode resolves it only at build time.
    bundle_id = ENV["BUNDLE_ID"]
    app_name  = ENV["APP_NAME"] || bundle_id
    UI.user_error!("BUNDLE_ID env var is missing") if bundle_id.nil? || bundle_id.empty?
    UI.message("Building bundle id: #{bundle_id}")

    # 3) Ensure the bundle id is registered in Developer Portal + App Store Connect.
    # We use Spaceship::ConnectAPI directly (token was set globally in step 1)
    # because `produce` in this fastlane version still requires an Apple ID
    # username, which would force interactive 2FA in CI.
    require "spaceship"

    UI.message("Checking Developer Portal for bundle id: #{bundle_id}")
    if Spaceship::ConnectAPI::BundleId.find(bundle_id).nil?
      UI.message("Registering bundle id in Developer Portal…")
      Spaceship::ConnectAPI::BundleId.create(
        name: app_name.gsub(/[^a-zA-Z0-9 ]/, "").strip,
        identifier: bundle_id,
        platform: "IOS"
      )
      UI.success("Bundle id registered: #{bundle_id}")
    else
      UI.message("Bundle id already registered.")
    end

    UI.message("Checking App Store Connect for app: #{bundle_id}")
    if Spaceship::ConnectAPI::App.find(bundle_id).nil?
      UI.user_error!(<<~MSG)
        App record not found in App Store Connect for bundle id '#{bundle_id}'.

        Apple no longer allows creating App Store Connect apps via API. You need
        to create it once in the web UI, then re-run this build:

          1. Go to https://appstoreconnect.apple.com/apps
          2. Click '+' → 'New App'
          3. Platform: iOS
             Name: #{app_name}
             Primary Language: English (U.S.) or the store's language
             Bundle ID: choose '#{bundle_id}' from the dropdown (already registered in Dev Portal)
             SKU: #{bundle_id.gsub('.', '_')}
             User Access: Full Access
          4. Save. Then trigger this build again.
      MSG
    else
      UI.message("App record already exists in App Store Connect.")
    end

    # 4) Sync signing certs + provisioning profiles via Match.
    # readonly=false so match can create a per-bundle provisioning profile
    # on first build of each store. The existing distribution cert in the
    # match repo is reused — match only ever creates missing profiles.
    match(
      type: "appstore",
      app_identifier: bundle_id,
      readonly: false,
      api_key: api_key
    )

    # 5) Bump build + version
    increment_build_number(
      xcodeproj: "App.xcodeproj",
      build_number: ENV["BUILD_NUMBER"]
    )
    increment_version_number(
      xcodeproj: "App.xcodeproj",
      version_number: ENV["VERSION_NAME"]
    )

    # 6) Build + sign
    build_app(
      scheme: "App",
      workspace: "App.xcworkspace",
      export_method: "app-store",
      configuration: "Release",
      clean: true,
      output_directory: "./build",
      output_name: "App.ipa"
    )

    # 7) Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
